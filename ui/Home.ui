  <property name="styleSheet">
   <string notr="true">#centralwidget {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #f5efe6, stop:0.52 #e7f0e8, stop:1 #e1e8f6);
    font-family: &quot;Segoe UI&quot;;
}

QFrame#headerCard,
QFrame#filterCard,
QFrame#sidebarCard,
QFrame#sessionCard {
    background-color: rgba(255, 252, 247, 245);
    border: 1px solid rgba(24, 57, 43, 25);
    border-radius: 28px;
}

QTabWidget::pane {
    border: 1px solid rgba(24, 57, 43, 25);
    background: rgba(255, 252, 247, 230);
    border-radius: 24px;
    top: -1px;
}

QTabBar::tab {
    background: rgba(24, 57, 43, 12);
    color: #234132;
    padding: 12px 20px;
    margin-right: 8px;
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
    font-weight: 600;
}

QTabBar::tab:selected {
    background: #d96b43;
    color: white;
}

QGroupBox {
    border: 1px solid rgba(24, 57, 43, 30);
    border-radius: 22px;
    margin-top: 16px;
    padding-top: 16px;
    background-color: rgba(255, 252, 247, 235);
    font-size: 11pt;
    font-weight: 700;
    color: #173326;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 18px;
    padding: 0 6px;
}

QLabel#lblPageTag {
    color: #b25b3a;
    font-size: 10pt;
    font-weight: 700;
    letter-spacing: 2px;
}

QLabel#lblWelcome {
    color: #173326;
    font-size: 24pt;
    font-weight: 700;
}

QLabel#lblSessionNote,
QLabel#lblProductCounter,
QLabel#lblSidebarHint,
QLabel#lblAdminHint,
QLabel#lblCurrentUserTitle,
QLabel#lblCurrentRoleTitle,
QLabel#lblCurrentUser,
QLabel#lblCurrentRole,
QLabel#lblSelectedProductTitle,
QLabel#lblSelectedProduct {
    color: #506056;
}

QLineEdit,
QComboBox,
QSpinBox {
    min-height: 42px;
    background-color: #fffdf8;
    border: 1px solid #d8e1d8;
    border-radius: 16px;
    padding: 0 14px;
    color: #173326;
    font-size: 10.5pt;
}

QLineEdit:focus,
QComboBox:focus,
QSpinBox:focus {
    border: 2px solid #d96b43;
}

QPushButton {
    min-height: 42px;
    border-radius: 16px;
    border: none;
    font-size: 10.5pt;
    font-weight: 700;
    padding: 0 16px;
}

QPushButton#btnOpenCart,
QPushButton#btnAddProduct,
QPushButton#btnUpdateProduct {
    background-color: #d96b43;
    color: white;
}

QPushButton#btnOpenCart:hover,
QPushButton#btnAddProduct:hover,
QPushButton#btnUpdateProduct:hover {
    background-color: #c45e39;
}

QPushButton#btnResetFilters,
QPushButton#btnClearProductForm,
QPushButton#btnLogout,
QPushButton#btnOpenUser {
    background-color: rgba(24, 57, 43, 10);
    color: #173326;
    border: 1px solid rgba(24, 57, 43, 35);
}

QPushButton#btnDeleteProduct {
    background-color: #8f2f2f;
    color: white;
}

QPushButton#btnDeleteProduct:hover {
    background-color: #7a2525;
}
</string>
