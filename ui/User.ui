}

QFrame#profileCard,
QFrame#formCard {
    background-color: rgba(255, 252, 247, 245);
    border: 1px solid rgba(24, 57, 43, 25);
    border-radius: 28px;
}

QLabel#lblPageTag {
    color: #b25b3a;
    font-size: 10pt;
    font-weight: 700;
    letter-spacing: 2px;
}

