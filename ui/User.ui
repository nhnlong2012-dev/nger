}

QLabel#lblAvatarPreview {
    background-color: rgba(24, 57, 43, 10);
    border: 1px solid rgba(24, 57, 43, 25);
    border-radius: 26px;
    color: #173326;
    font-size: 12pt;
    font-weight: 700;
}

QLineEdit {
    min-height: 44px;
    background-color: #fffdf8;
    border: 1px solid #d8e1d8;
    border-radius: 16px;
    padding: 0 14px;
    color: #173326;
    font-size: 10.5pt;
}

QLineEdit:focus {
    border: 2px solid #d96b43;
}

QPushButton {
    min-height: 42px;
    border-radius: 16px;
    border: none;
    font-size: 10.5pt;
    font-weight: 700;
    padding: 0 16px;
}

QPushButton#btnSaveUser,
QPushButton#btnChooseAvatar {
    background-color: #d96b43;
    color: white;
}

QPushButton#btnSaveUser:hover,
QPushButton#btnChooseAvatar:hover {
    background-color: #c45e39;
}

QPushButton#btnBackHome,
QPushButton#btnClearAvatar {
    background-color: rgba(24, 57, 43, 10);
    color: #173326;
    border: 1px solid rgba(24, 57, 43, 35);
}
</string>
