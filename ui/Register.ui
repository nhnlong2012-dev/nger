   <string notr="true">#centralwidget {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #f7f1e7, stop:0.52 #e6efe8, stop:1 #e1e8f6);
    font-family: &quot;Segoe UI&quot;;
}

QFrame#formCard {
    background-color: rgba(255, 252, 247, 245);
    border: 1px solid rgba(24, 57, 43, 25);
    border-radius: 32px;
}

QFrame#heroPanel {
    background-color: #18392b;
    border-radius: 32px;
}

QFrame#heroAccent {
    background-color: rgba(255, 255, 255, 22);
    border: 1px solid rgba(255, 255, 255, 30);
    border-radius: 24px;
}

QLabel#formEyebrow {
    color: #b25b3a;
    font-size: 10pt;
    font-weight: 700;
    letter-spacing: 2px;
}

QLabel#formTitle {
    color: #173326;
    font-size: 24pt;
    font-weight: 700;
}

QLabel#formSubtitle,
QLabel#usernameLabel,
QLabel#emailLabel,
QLabel#passwordLabel,
QLabel#confirmLabel,
QLabel#bottomHint {
    color: #506056;
}

QLabel#usernameLabel,
QLabel#emailLabel,
QLabel#passwordLabel,
QLabel#confirmLabel {
    font-size: 10pt;
    font-weight: 600;
}

QLabel#brandBadge {
    background-color: rgba(255, 255, 255, 25);
    color: #f7f2e9;
    border-radius: 16px;
    padding: 8px 14px;
    font-size: 11pt;
    font-weight: 700;
    letter-spacing: 1px;
}

QLabel#heroTitle {
    color: white;
    font-size: 30pt;
    font-weight: 700;
}

QLabel#heroSubtitle,
QLabel#heroMetaTitle,
QLabel#heroMetaText {
    color: #dce9e1;
}

QLineEdit {
    background-color: #fffdf8;
    border: 1px solid #d8e1d8;
    border-radius: 16px;
    padding: 0 16px;
    color: #173326;
    selection-background-color: #d96b43;
    font-size: 10.5pt;
}

QLineEdit:focus {
    border: 2px solid #d96b43;
    background-color: #ffffff;
}

QCheckBox {
    color: #415248;
    spacing: 10px;
    font-size: 10pt;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 6px;
    border: 1px solid #95a59b;
    background-color: white;
}

QCheckBox::indicator:checked {
    background-color: #d96b43;
    border: 1px solid #d96b43;
}

QPushButton#btnRegister {
    background-color: #d96b43;
    color: white;
    border: none;
    border-radius: 18px;
    font-size: 12pt;
    font-weight: 700;
}

QPushButton#btnRegister:hover {
    background-color: #c65f39;
}

QPushButton#btnRegister:pressed {
    background-color: #af5331;
}

QPushButton#loginAccount {
    background-color: transparent;
    color: #18392b;
    border: 1px solid rgba(24, 57, 43, 55);
    border-radius: 16px;
    font-size: 10pt;
    font-weight: 600;
}

QPushButton#loginAccount:hover {
    background-color: rgba(24, 57, 43, 10);
}
