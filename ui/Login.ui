  <property name="styleSheet">
   <string notr="true">#centralwidget {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #f6efe5, stop:0.55 #e7f0ea, stop:1 #dfe8f5);
    font-family: &quot;Segoe UI&quot;;
}

QFrame#heroPanel {
    background-color: #18392b;
    border-radius: 32px;
}

QFrame#heroGlass {
    background-color: rgba(255, 255, 255, 22);
    border: 1px solid rgba(255, 255, 255, 30);
    border-radius: 24px;
}

QFrame#formCard {
    background-color: rgba(255, 252, 247, 245);
    border: 1px solid rgba(24, 57, 43, 25);
    border-radius: 32px;
}

QLabel#brandBadge {
    background-color: rgba(255, 255, 255, 25);
    color: #f7f2e9;
    border-radius: 16px;
    padding: 8px 14px;
    font-size: 11pt;
    font-weight: 700;
    letter-spacing: 1px;
}

QLabel#heroTitle {
    color: white;
    font-size: 30pt;
    font-weight: 700;
}

QLabel#heroSubtitle,
QLabel#heroMetaTitle,
QLabel#heroMetaText {
    color: #dce9e1;
}

QLabel#formEyebrow {
    color: #b25b3a;
    font-size: 10pt;
    font-weight: 700;
    letter-spacing: 2px;
}

QLabel#formTitle {
    color: #173326;
    font-size: 24pt;
    font-weight: 700;
}

QLabel#formSubtitle,
QLabel#emailLabel,
QLabel#passwordLabel,
QLabel#helpText,
QLabel#hintText {
    color: #506056;
}

QLabel#emailLabel,
QLabel#passwordLabel {
    font-size: 10pt;
    font-weight: 600;
}

QLineEdit {
    background-color: #fffdf8;
    border: 1px solid #d8e1d8;
    border-radius: 18px;
    padding: 0 18px;
    color: #173326;
    selection-background-color: #d96b43;
    font-size: 11pt;
}

QLineEdit:focus {
    border: 2px solid #d96b43;
    background-color: #ffffff;
}

QPushButton#btnLogin {
    background-color: #d96b43;
    color: white;
    border: none;
    border-radius: 18px;
    font-size: 12pt;
    font-weight: 700;
}

QPushButton#btnLogin:hover {
    background-color: #c65f39;
}

QPushButton#btnLogin:pressed {
    background-color: #af5331;
}

QPushButton#createAccount {
    background-color: transparent;
    color: #18392b;
    border: 1px solid rgba(24, 57, 43, 55);
    border-radius: 16px;
    font-size: 10pt;
    font-weight: 600;
}

QPushButton#createAccount:hover {
    background-color: rgba(24, 57, 43, 10);
}
</string>
